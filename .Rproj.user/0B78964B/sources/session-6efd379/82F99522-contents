## Which Countries Show Fertility Trends Most Similar to China?

```{r warning=FALSE, message=FALSE} library(tidyverse)  fertility <- read.csv("children-per-woman-un.csv", check.names = FALSE) names(fertility)[4] <- "fertility_rate"  # China's 2023 fertility rate china_rate <- fertility |>   dplyr::filter(Entity == "China") |>   dplyr::pull(fertility_rate)  # Calculate absolute difference from China's rate for all countries fertility_diff <- fertility |>   dplyr::filter(Entity != "China") |>   dplyr::mutate(diff_from_china = abs(fertility_rate - china_rate)) |>   dplyr::arrange(diff_from_china) |>   dplyr::slice_head(n = 10)  # Select comparison countries (top 5 closest + China) comparison_countries <- c("China", fertility_diff$Entity[1:5])  fertility_compare <- fertility |>   dplyr::filter(Entity %in% comparison_countries) |>   dplyr::mutate(Entity = forcats::fct_reorder(Entity, fertility_rate))  ggplot2::ggplot(fertility_compare,                 ggplot2::aes(x = Entity, y = fertility_rate, fill = Entity == "China")) +   ggplot2::geom_col(show.legend = FALSE) +   ggplot2::geom_hline(yintercept = china_rate, linetype = "dashed", colour = "#e74c3c", linewidth = 0.8) +   ggplot2::annotate("text", x = 1, y = china_rate + 0.04,                     label = paste0("China: ", china_rate), colour = "#e74c3c", size = 4, hjust = 0) +   ggplot2::scale_fill_manual(values = c("grey70", "#e74c3c")) +   ggplot2::labs(     title = "Countries with Fertility Rates Most Similar to China (2023)",     subtitle = "Top 5 closest countries by absolute difference in fertility rate",     x = "Country",     y = "Fertility Rate (children per woman)",     caption = "Data Source: UN, World Population Prospects (2024) – processed by Our World in Data"   ) +   ggplot2::theme_minimal(base_size = 16) +   ggplot2::theme(     plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),     plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),     axis.title = ggplot2::element_text(face = "bold"),     panel.grid.major.x = ggplot2::element_blank(),     panel.grid.minor = ggplot2::element_blank()   )}
