library(tidyverse)
life_exp <- read.csv("life-expectancy.csv", check.names = FALSE)
names(life_exp)[4] <- "life_expectancy"
# Filter from 1950 onwards for a clean modern comparison
life_exp_filtered <- life_exp |>
dplyr::filter(Year >= 1950) |>
dplyr::mutate(
Entity = dplyr::recode(Entity,
"Upper-middle-income countries" = "Upper-Middle-Income Countries")
)
ggplot2::ggplot(life_exp_filtered,
ggplot2::aes(x = Year, y = life_expectancy,
colour = Entity)) +
ggplot2::geom_line(ggplot2::aes(linewidth = Entity == "China")) +
ggplot2::scale_linewidth_manual(values = c("TRUE" = 1.4, "FALSE" = 0.7),
guide = "none") +
ggplot2::scale_colour_brewer(palette = "Set1") +
ggplot2::scale_x_continuous(breaks = seq(1950, 2023, by = 10)) +
ggplot2::labs(
title = "Life Expectancy Over Time: China vs Global Benchmarks",
subtitle = "1950–2023",
x = "Year",
y = "Life Expectancy (years)",
colour = "Entity",
caption = "Data Source: Human Mortality Database; UN World Population Prospects (2024) – processed by Our World in Data"
) +
ggplot2::theme_minimal(base_size = 16) +
ggplot2::theme(
plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
legend.position = "bottom",
panel.grid.minor = ggplot2::element_blank(),
panel.grid.major.x = ggplot2::element_blank()
)
library(tidyverse)
life_exp <- read.csv("life-expectancy.csv", check.names = FALSE)
names(life_exp)[4] <- "life_expectancy"
# For each entity, pick the closest available row to each target year
target_years <- c(1950, 1980, 2000, 2023)
milestones <- life_exp |>
dplyr::filter(Year >= 1950) |>
dplyr::group_by(Entity) |>
dplyr::filter(Year %in% target_years) |>
dplyr::ungroup() |>
dplyr::mutate(
life_expectancy = round(life_expectancy, 1),
Year = factor(Year)
)
ggplot2::ggplot(milestones,
ggplot2::aes(x = Year, y = life_expectancy, fill = Entity)) +
ggplot2::geom_col(position = ggplot2::position_dodge2(preserve = "single")) +
ggplot2::geom_text(ggplot2::aes(label = life_expectancy),
position = ggplot2::position_dodge2(width = 0.9, preserve = "single"),
vjust = -0.4, size = 3.2, fontface = "bold") +
ggplot2::scale_fill_brewer(palette = "Spectral") +
ggplot2::labs(
title = "Life Expectancy at Key Milestones: China vs Benchmarks",
subtitle = "Selected years: 1950, 1980, 2000, 2023",
x = "Year",
y = "Life Expectancy (years)",
fill = "Entity",
caption = "Data Source: Human Mortality Database; UN World Population Prospects (2024) – processed by Our World in Data"
) +
ggplot2::theme_minimal(base_size = 16) +
ggplot2::theme(
plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
panel.grid.major.x = ggplot2::element_blank(),
panel.grid.minor = ggplot2::element_blank(),
legend.position = "bottom"
)
library(tidyverse)
life_exp <- read.csv("life-expectancy.csv", check.names = FALSE)
names(life_exp)[4] <- "life_expectancy"
# Calculate gain from 1950 to 2023
gain_table <- life_exp |>
dplyr::filter(Year %in% c(1950, 2023)) |>
dplyr::select(Entity, Year, life_expectancy) |>
tidyr::pivot_wider(names_from = Year, values_from = life_expectancy,
names_prefix = "Year_") |>
dplyr::mutate(
`1950` = round(Year_1950, 1),
`2023` = round(Year_2023, 1),
`Gain (years)` = round(Year_2023 - Year_1950, 1),
`% Increase` = paste0(round(((Year_2023 - Year_1950) / Year_1950) * 100, 1), "%")
) |>
dplyr::select(Entity, `1950`, `2023`, `Gain (years)`, `% Increase`)
knitr::kable(gain_table,
caption = "Life Expectancy: 1950 vs 2023 by Entity",
align = c("l", "c", "c", "c", "c"))
library(tidyverse)
fertility <- read.csv("children-per-woman-un.csv", check.names = FALSE)
names(fertility)[4] <- "fertility_rate"
# China's 2023 fertility rate
china_rate <- fertility |>
dplyr::filter(Entity == "China") |>
dplyr::pull(fertility_rate)
# Calculate absolute difference from China's rate for all countries
fertility_diff <- fertility |>
dplyr::filter(Entity != "China") |>
dplyr::mutate(diff_from_china = abs(fertility_rate - china_rate)) |>
dplyr::arrange(diff_from_china) |>
dplyr::slice_head(n = 10)
# Select comparison countries (top 5 closest + China)
comparison_countries <- c("China", fertility_diff$Entity[1:5])
fertility_compare <- fertility |>
dplyr::filter(Entity %in% comparison_countries) |>
dplyr::mutate(Entity = forcats::fct_reorder(Entity, fertility_rate))
ggplot2::ggplot(fertility_compare,
ggplot2::aes(x = Entity, y = fertility_rate, fill = Entity == "China")) +
ggplot2::geom_col(show.legend = FALSE) +
ggplot2::geom_hline(yintercept = china_rate, linetype = "dashed", colour = "#e74c3c", linewidth = 0.8) +
ggplot2::annotate("text", x = 1, y = china_rate + 0.04,
label = paste0("China: ", china_rate), colour = "#e74c3c", size = 4, hjust = 0) +
ggplot2::scale_fill_manual(values = c("grey70", "#e74c3c")) +
ggplot2::labs(
title = "Countries with Fertility Rates Most Similar to China (2023)",
subtitle = "Top 5 closest countries by absolute difference in fertility rate",
x = "Country",
y = "Fertility Rate (children per woman)",
caption = "Data Source: UN, World Population Prospects (2024) – processed by Our World in Data"
) +
ggplot2::theme_minimal(base_size = 16) +
ggplot2::theme(
plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
axis.title = ggplot2::element_text(face = "bold"),
panel.grid.major.x = ggplot2::element_blank(),
panel.grid.minor = ggplot2::element_blank()
)
