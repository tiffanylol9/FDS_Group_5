plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
axis.title = ggplot2::element_text(face = "bold"),
panel.grid.major.x = ggplot2::element_blank(),
panel.grid.minor = ggplot2::element_blank()
)
library(tidyverse)
fertility <- read.csv("children-per-woman-un.csv", check.names = FALSE)
names(fertility)[4] <- "fertility_rate"
china_rate <- fertility |>
dplyr::filter(Entity == "China") |>
dplyr::pull(fertility_rate)
# Select top 5 closest + China for a grouped comparison
close_countries <- c("China", "Ukraine", "South Korea", "Taiwan", "Puerto Rico", "Singapore")
fertility_compare <- fertility |>
dplyr::filter(Entity %in% close_countries) |>
dplyr::mutate(
diff = abs(fertility_rate - china_rate),
Entity = forcats::fct_reorder(Entity, fertility_rate, .desc = TRUE),
highlight = dplyr::if_else(Entity == "China", "China", "Comparison Country")
)
ggplot2::ggplot(fertility_compare,
ggplot2::aes(x = Entity, y = fertility_rate,
colour = highlight, group = 1)) +
ggplot2::geom_point(size = 6) +
ggplot2::geom_segment(ggplot2::aes(xend = Entity, y = 0, yend = fertility_rate),
linewidth = 1.2) +
ggplot2::geom_text(ggplot2::aes(label = round(fertility_rate, 3)),
vjust = -1, size = 4.5, fontface = "bold") +
ggplot2::scale_colour_manual(values = c("China" = "#e74c3c", "Comparison Country" = "#2980b9")) +
ggplot2::labs(
title = "Fertility Rate Pattern Similarity to China (2023)",
subtitle = "Countries ranked by proximity to China's fertility rate of 0.999",
x = "Country",
y = "Fertility Rate (children per woman)",
colour = NULL,
caption = "Data Source: UN, World Population Prospects (2024) – processed by Our World in Data"
) +
ggplot2::theme_minimal(base_size = 16) +
ggplot2::theme(
plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
legend.position = "top",
panel.grid.major.x = ggplot2::element_blank()
)
library(tidyverse)
fertility <- read.csv("children-per-woman-un.csv", check.names = FALSE)
names(fertility)[4] <- "fertility_rate"
china_rate <- fertility |>
dplyr::filter(Entity == "China") |>
dplyr::pull(fertility_rate)
# Summary table: 10 closest countries
fertility |>
dplyr::filter(Entity != "China") |>
dplyr::mutate(diff_from_china = round(abs(fertility_rate - china_rate), 4)) |>
dplyr::arrange(diff_from_china) |>
dplyr::slice_head(n = 10) |>
dplyr::select(Country = Entity, `Fertility Rate` = fertility_rate, `Difference from China` = diff_from_china) |>
knitr::kable(caption = "Top 10 Countries with Fertility Rates Closest to China (2023)",
align = c("l", "c", "c"))
library(tidyverse)
life_exp <- read.csv("life-expectancy.csv", check.names = FALSE)
names(life_exp)[4] <- "life_expectancy"
# Calculate gain for each entity from 1950 to 2023
milestones <- life_exp |>
dplyr::filter(Year %in% c(1950, 1980, 2000, 2023)) |>
dplyr::mutate(life_expectancy = round(life_expectancy, 1))
ggplot2::ggplot(milestones,
ggplot2::aes(x = factor(Year), y = life_expectancy,
fill = Entity)) +
ggplot2::geom_col(position = "dodge") +
ggplot2::geom_text(ggplot2::aes(label = life_expectancy),
position = ggplot2::position_dodge(width = 0.9),
vjust = -0.4, size = 3.2, fontface = "bold") +
ggplot2::scale_fill_brewer(palette = "Spectral") +
ggplot2::labs(
title = "Life Expectancy at Key Milestones: China vs Benchmarks",
subtitle = "Selected years: 1950, 1980, 2000, 2023",
x = "Year",
y = "Life Expectancy (years)",
fill = "Entity",
caption = "Data Source: Human Mortality Database; UN World Population Prospects (2024) – processed by Our World in Data"
) +
ggplot2::theme_minimal(base_size = 16) +
ggplot2::theme(
plot.title = ggplot2::element_text(face = "bold", size = 16, hjust = 0.5),
plot.subtitle = ggplot2::element_text(size = 12, hjust = 0.5, colour = "grey40"),
panel.grid.major.x = ggplot2::element_blank(),
panel.grid.minor = ggplot2::element_blank(),
legend.position = "bottom"
)
