gain_table <- life_exp |>
dplyr::filter(Year %in% c(1950, 2023)) |>
dplyr::select(Entity, Year, life_expectancy) |>
tidyr::pivot_wider(names_from = Year, values_from = life_expectancy,
names_prefix = "Year_") |>
dplyr::mutate(
`1950` = round(Year_1950, 1),
`2023` = round(Year_2023, 1),
`Gain (years)` = round(Year_2023 - Year_1950, 1),
`% Increase` = paste0(round(((Year_2023 - Year_1950) / Year_1950) * 100, 1), "%")
) |>
dplyr::select(Entity, `1950`, `2023`, `Gain (years)`, `% Increase`)
knitr::kable(gain_table,
caption = "Life Expectancy: 1950 vs 2023 by Entity",
align = c("l", "c", "c", "c", "c"))
